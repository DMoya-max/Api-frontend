<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('../partials/head'); %>
</head>

<body class="container">
    <header>
        <%- include('../partials/header'); %>
    </header>
    <main>
        <div class="jumbotron">
            <h1>Listado de Servicios</h1>
            <% if (servicios && servicios.length> 0) { %>
                <table id="tablita" border="1" cellpadding="5" cellspacing="0" class="table table-striped">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Descripcion</th>
                            <th>Duracion Minutos</th>
                            <th>Precio</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% servicios.forEach(function(servicio) { %>
                            <tr>
                                <td>
                                    <%= servicio.nombre %>
                                </td>
                                <td>
                                    <%= servicio.descripcion %>
                                </td>
                                <td>
                                    <%= servicio.duracionMinutos || servicio.duracion || 'N/A' %>
                                </td>
                                <td>$<%= servicio.precio %>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-outline-primary"> Ver detalles </button>
                                    <button type="button" class="btn btn-outline-success"> Editar </button>
                                    <button type="button" class="btn btn-outline-danger"> Eliminar </button>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>
                <% } else { %>
                    <p>No hay servicios registrados.</p>
                    <% } %>
        </div>
    </main>
    <footer>
        <%- include('../partials/footer'); %>
    </footer>
</body>

</html>